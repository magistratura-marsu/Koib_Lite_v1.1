# ═══════════════════════════════════════════════════════════
# Koib-V-4.8 — Конфигурация с двумя профилями
# ═══════════════════════════════════════════════════════════
# СХЕМА РАБОТЫ:
#   1. ИНДЕКСАЦИЯ на домашнем ПК (20 ГБ RAM + GPU) → быстрая сборка
#   2. ПЕРЕНОС папки ./output на VPS (2 ГБ RAM)
#   3. INFERENCE на VPS с экономными настройками
#
# ⚠️  ВАЖНО: LOCAL_EMBEDDING_MODEL должна быть ОДИНАКОВОЙ на обоих машинах!
#     Иначе векторный поиск сломается (несовместимые пространства).
# ═══════════════════════════════════════════════════════════

# === Пути ===
KOIB_DOCS_DIR=./data/docs
KOIB_OUTPUT_DIR=./output

# === LLM Provider ===
LLM_PROVIDER=gigachat

# === GigaChat ===
GIGACHAT_CREDENTIALS=
GIGACHAT_MODEL=GigaChat
GIGACHAT_TEMPERATURE=0.2
GIGACHAT_MAX_TOKENS=1536
GIGACHAT_TIMEOUT=45
GIGACHAT_VERIFY_SSL=false

# === OpenAI (если LLM_PROVIDER=openai) ===
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=1536

# === Local LLM (если LLM_PROVIDER=local, Ollama) ===
LOCAL_LLM_MODEL=IlyaGusev/saiga_mistral_7b
LOCAL_LLM_URL=http://localhost:11434

# === Embeddings (ОБЯЗАТЕЛЬНО ОДИНАКОВОЕ ЗНАЧЕНИЕ НА PC И VPS!) ===
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=intfloat/multilingual-e5-small
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# === Chunking ===
TEXT_CHUNK_SIZE=800
TEXT_CHUNK_OVERLAP=80
MIN_CHUNK_LENGTH=50

# === Retrieval ===
VECTOR_SEARCH_K=15
BM25_SEARCH_K=10
FINAL_TOP_K=4
HYBRID_ALPHA=0.6
BM25_USE_STOPWORDS=true
USE_HYDE=false

# === Reranker ===
USE_RERANKER=true
RERANKER_MODEL=DiTy/ru-reranker-base
USE_ONNX_RERANKER=true

# === Parsing (PDF/DOCX) ===
OCR_MIN_TEXT_CHARS=50
MIN_IMAGE_WIDTH=80
MIN_IMAGE_HEIGHT=80

# === Validation ===
VALIDATION_IGNORE_QUOTES=true
UNCERTAINTY_MIN_LENGTH=50

# === Semantic Cache ===
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.92

# === API Server ===
API_HOST=0.0.0.0
API_PORT=8000

# === VK Bot ===
VK_CONFIRM_CODE=12345678
VK_GROUP_ID=
VK_ACCESS_TOKEN=

# ═══════════════════════════════════════════════════════════
# ★ ПРОФИЛЬ 1: ДОМАШНИЙ ПК (индексация)
# Раскомментируйте этот блок на ПК с 20 ГБ RAM + GPU
# ═══════════════════════════════════════════════════════════
OCR_DPI=300
INDEXING_BATCH_SIZE=1024
INDEXING_FLUSH_THRESHOLD=50000
INDEXING_DEVICE=auto
MAX_CONCURRENT_GENERATIONS=8

# ═══════════════════════════════════════════════════════════
# ★ ПРОФИЛЬ 2: VPS (inference)
# Раскомментируйте этот блок на сервере с 2 ГБ RAM
# ═══════════════════════════════════════════════════════════
# OCR_DPI=150
# INDEXING_BATCH_SIZE=64
# INDEXING_FLUSH_THRESHOLD=2000
# INDEXING_DEVICE=cpu
# MAX_CONCURRENT_GENERATIONS=2
