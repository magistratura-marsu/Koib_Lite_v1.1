# Koib-V-4.5 — Пример конфигурации

KOIB_DOCS_DIR=./data/docs
KOIB_OUTPUT_DIR=./output

LLM_PROVIDER=gigachat
EMBEDDING_PROVIDER=local

LOCAL_EMBEDDING_MODEL=intfloat/multilingual-e5-small
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=

GIGACHAT_CREDENTIALS=
GIGACHAT_MODEL=GigaChat
GIGACHAT_TEMPERATURE=0.2
GIGACHAT_MAX_TOKENS=1024
GIGACHAT_TIMEOUT=30
GIGACHAT_VERIFY_SSL=false

OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=1024

LOCAL_LLM_MODEL=IlyaGusev/saiga_mistral_7b
LOCAL_LLM_URL=http://localhost:11434

TEXT_CHUNK_SIZE=800
TEXT_CHUNK_OVERLAP=80
MIN_CHUNK_LENGTH=50

VECTOR_SEARCH_K=12
BM25_SEARCH_K=8
FINAL_TOP_K=3
HYBRID_ALPHA=0.6

USE_RERANKER=true
RERANKER_MODEL=DiTy/ru-reranker-base

USE_HYDE=false

BM25_USE_STOPWORDS=true

VALIDATION_IGNORE_QUOTES=true
UNCERTAINTY_MIN_LENGTH=50

OCR_DPI=300
OCR_MIN_TEXT_CHARS=50
MIN_IMAGE_WIDTH=80
MIN_IMAGE_HEIGHT=80

API_HOST=0.0.0.0
API_PORT=8000
VK_CONFIRM_CODE=12345678
VK_GROUP_ID=
VK_ACCESS_TOKEN=